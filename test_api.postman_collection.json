{
  "info": {
    "name": "Book Store API - Test Collection",
    "description": "Collection để test các API của hệ thống book store",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Nguyễn Văn A\",\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\",\n  \"phone\": \"0987654321\",\n  \"address\": \"Hà Nội\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "register"
          ]
        }
      }
    },
    {
      "name": "2. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const cookies = pm.response.headers.get('Set-Cookie');",
              "    if (cookies) {",
              "        const jwtMatch = cookies.match(/JWT_TOKEN=([^;]+)/);",
              "        if (jwtMatch) {",
              "            pm.collectionVariables.set('jwtToken', jwtMatch[1]);",
              "            console.log('JWT Token saved:', jwtMatch[1]);",
              "        }",
              "    }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "login"
          ]
        }
      }
    },
    {
      "name": "3. Get All Users (Admin)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "JWT_TOKEN={{jwtToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users"
          ]
        }
      }
    },
    {
      "name": "4. Create Admin User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "JWT_TOKEN={{jwtToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"phone\": \"0123456789\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users"
          ]
        }
      }
    },
    {
      "name": "5. Update Profile",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "JWT_TOKEN={{jwtToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Nguyễn Văn B\",\n  \"phone\": \"0987654322\",\n  \"address\": \"TP.HCM\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "profile"
          ]
        }
      }
    },
    {
      "name": "6. Change Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "JWT_TOKEN={{jwtToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"oldPassword\": \"123456\",\n  \"newPassword\": \"newpassword123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/change-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "change-password"
          ]
        }
      }
    },
    {
      "name": "Test Authentication - Without Token",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Test Without Auth\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "profile"
          ]
        }
      }
    }
  ]
}